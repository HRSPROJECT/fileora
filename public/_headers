# ==========================================
# Fileora Cloudflare Pages HTTP Response Headers
# ==========================================

# 1. Global Security and Content Security Policy (CSP) Rules
/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: credentialless
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' blob: https://unpkg.com https://*.googletagmanager.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.google-analytics.com https://*.analytics.google.com https://*.google.com https://*.googletagmanager.com https://*.producthunt.com https://producthunt.com https://fonts.gstatic.com; media-src 'self' blob:; connect-src 'self' blob: https://unpkg.com https://fonts.googleapis.com https://fonts.gstatic.com https://www.googletagmanager.com https://*.google-analytics.com https://*.analytics.google.com https://*.google.com https://static.cloudflareinsights.com https://*.peerjs.com wss://*.peerjs.com; worker-src 'self' blob:; child-src 'self' blob:; frame-ancestors 'none';

# 2. Immutable Cache Controls for Vite Assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable


# 3. Server-Side Robots Directives for Dead Pages
/404
  X-Robots-Tag: noindex, nofollow

